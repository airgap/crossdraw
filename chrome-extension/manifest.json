{
  "manifest_version": 3,
  "name": "Crossdraw Text Picker",
  "version": "1.0.0",
  "description": "Select text on any website and copy its content + full styling to paste into Crossdraw.",
  "permissions": ["activeTab", "clipboardWrite"],
  "action": {
    "default_title": "Pick text style (Alt+Shift+T)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+T"
      },
      "description": "Activate text picker"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
