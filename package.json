{
  "name": "designer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx tsc -b && bunx vite build",
    "preview": "bunx vite preview",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint src/",
    "electron:build": "bun run build && bunx tsc -p electron/tsconfig.json",
    "electron:dev": "bunx tsc -p electron/tsconfig.json && VITE_DEV_SERVER_URL=http://localhost:5173 bunx electron dist-electron/main.js",
    "electron:pack": "bun run electron:build && bunx electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "bezier-js": "^6.1.4",
    "chroma-js": "^3.1.2",
    "clipper-lib": "^6.4.2",
    "electron-store": "^11.0.2",
    "immer": "^10.1.1",
    "lucide-react": "^0.577.0",
    "msgpackr": "^1.11.2",
    "rbush": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/bun": "^1.3.10",
    "@types/chroma-js": "^2.4.4",
    "@types/electron": "^1.6.12",
    "@types/rbush": "^4.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.4"
  }
}
